{
  "name": "vscode-xlens",
  "displayName": "XLens",
  "description": "Developer lens for monorepo workflows — changed files tree, diff explorer, presets, and more",
  "version": "0.2.1",
  "publisher": "l8ng",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/straydragon/vscode-xlens"
  },
  "engines": {
    "vscode": "^1.105.1"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "git",
    "diff",
    "changed files",
    "monorepo",
    "tree view",
    "presets",
    "bookmarks"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:gitDiffExplorerView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "gitDiffExplorerView",
          "name": "XLens",
          "icon": "resources/diff-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "xlens.gitDiffView.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "xlens.showPresets",
        "title": "Presets",
        "icon": "$(list-tree)"
      },
      {
        "command": "xlens.preset.switchToLive",
        "title": "XLens: Switch to Live View"
      },
      {
        "command": "xlens.preset.addFiles",
        "title": "Add to Preset",
        "icon": "$(add)"
      },
      {
        "command": "xlens.preset.addFilesFromExplorer",
        "title": "Add to XLens Preset",
        "icon": "$(add)"
      },
      {
        "command": "xlens.preset.removeFiles",
        "title": "Remove from Preset",
        "icon": "$(remove)"
      },
      {
        "command": "xlens.gitDiffView.openDiff",
        "title": "Open Diff",
        "icon": "$(diff)"
      },
      {
        "command": "xlens.gitDiffView.openFile",
        "title": "Open File"
      },
      {
        "command": "xlens.gitDiffView.copyPath",
        "title": "Copy Relative Path"
      },
      {
        "command": "xlens.gitDiffView.changeBaseBranch",
        "title": "Change Base Branch",
        "icon": "$(git-branch)"
      },
      {
        "command": "xlens.gitDiffView.newFile",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "xlens.gitDiffView.revealInExplorer",
        "title": "Reveal in File Explorer",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "xlens.gitDiffView.revealActiveFile",
        "title": "Reveal in XLens",
        "icon": "$(target)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "xlens.showPresets",
          "when": "view == gitDiffExplorerView",
          "group": "navigation@1"
        },
        {
          "command": "xlens.gitDiffView.refresh",
          "when": "view == gitDiffExplorerView",
          "group": "navigation@2"
        },
        {
          "command": "xlens.gitDiffView.changeBaseBranch",
          "when": "view == gitDiffExplorerView",
          "group": "navigation@3"
        },
        {
          "command": "xlens.gitDiffView.revealActiveFile",
          "when": "view == gitDiffExplorerView",
          "group": "navigation@4"
        }
      ],
      "editor/title/context": [
        {
          "command": "xlens.gitDiffView.revealActiveFile",
          "group": "1_open"
        }
      ],
      "explorer/context": [
        {
          "command": "xlens.preset.addFilesFromExplorer",
          "when": "resourceScheme == file",
          "group": "2_workspace"
        }
      ],
      "view/item/context": [
        {
          "command": "xlens.gitDiffView.openDiff",
          "when": "view == gitDiffExplorerView && viewItem =~ /^file_/",
          "group": "inline"
        },
        {
          "command": "xlens.gitDiffView.openFile",
          "when": "view == gitDiffExplorerView && viewItem =~ /^file_/",
          "group": "1_open"
        },
        {
          "command": "xlens.preset.removeFiles",
          "when": "view == gitDiffExplorerView && viewItem =~ /_inPreset/",
          "group": "1_preset"
        },
        {
          "command": "xlens.preset.addFiles",
          "when": "view == gitDiffExplorerView",
          "group": "1_preset"
        },
        {
          "command": "xlens.gitDiffView.newFile",
          "when": "view == gitDiffExplorerView && viewItem =~ /folder/",
          "group": "2_new"
        },
        {
          "command": "xlens.gitDiffView.revealInExplorer",
          "when": "view == gitDiffExplorerView",
          "group": "3_nav"
        },
        {
          "command": "xlens.gitDiffView.copyPath",
          "when": "view == gitDiffExplorerView",
          "group": "4_copy"
        }
      ]
    },
    "configuration": {
      "title": "XLens",
      "properties": {
        "xlens.gitDiffView.baseBranch": {
          "type": "string",
          "default": "",
          "description": "Base branch for XLens git diff view. Leave empty to auto-detect (master → main → develop → trunk)."
        },
        "xlens.gitDiffView.filterPrefix": {
          "type": "string",
          "default": "",
          "description": "Path prefix filter for XLens git diff view. Leave empty to auto-detect from workspace folder relative to git root."
        },
        "xlens.gitDiffView.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh XLens git diff view when files change or git state updates."
        },
        "xlens.gitDiffView.refreshDebounce": {
          "type": "number",
          "default": 2000,
          "description": "Debounce interval in milliseconds for XLens git diff view auto-refresh."
        },
        "xlens.gitDiffView.autoReveal": {
          "type": "boolean",
          "default": false,
          "description": "Auto-reveal and expand the active editor file in the XLens git diff tree."
        },
        "xlens.gitDiffView.statusDisplay": {
          "type": "string",
          "default": "badge",
          "enum": [
            "badge",
            "description",
            "hidden"
          ],
          "enumDescriptions": [
            "Show git status as a colored badge decoration after the file name",
            "Show git status as description text next to the file name",
            "Hide git status indicators entirely"
          ],
          "description": "How XLens git diff view displays git status for changed files."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.1",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8"
}
