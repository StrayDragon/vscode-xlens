{
  "name": "vscode-xlens",
  "displayName": "XLens",
  "description": "Developer lens for monorepo workflows — changed files tree, diff explorer, and more",
  "version": "0.1.0",
  "publisher": "l8ng",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/straydragon/vscode-xlens"
  },
  "engines": {
    "vscode": "^1.105.1"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "git",
    "diff",
    "changed files",
    "monorepo",
    "tree view"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onView:gitDiffExplorerView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "gitDiffExplorerView",
          "name": "XLens: Changed Files",
          "icon": "resources/diff-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "gitDiffExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "gitDiffExplorer.openDiff",
        "title": "Open Diff",
        "icon": "$(diff)"
      },
      {
        "command": "gitDiffExplorer.openFile",
        "title": "Open File"
      },
      {
        "command": "gitDiffExplorer.copyPath",
        "title": "Copy Relative Path"
      },
      {
        "command": "gitDiffExplorer.changeBaseBranch",
        "title": "Change Base Branch",
        "icon": "$(git-branch)"
      },
      {
        "command": "gitDiffExplorer.newFile",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "gitDiffExplorer.revealInExplorer",
        "title": "Reveal in File Explorer",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "gitDiffExplorer.revealActiveFile",
        "title": "Reveal in XLens Changed Files",
        "icon": "$(target)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitDiffExplorer.refresh",
          "when": "view == gitDiffExplorerView",
          "group": "navigation"
        },
        {
          "command": "gitDiffExplorer.changeBaseBranch",
          "when": "view == gitDiffExplorerView",
          "group": "navigation"
        },
        {
          "command": "gitDiffExplorer.revealActiveFile",
          "when": "view == gitDiffExplorerView",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "gitDiffExplorer.revealActiveFile",
          "group": "1_open"
        }
      ],
      "view/item/context": [
        {
          "command": "gitDiffExplorer.openDiff",
          "when": "view == gitDiffExplorerView && viewItem =~ /^file_/",
          "group": "inline"
        },
        {
          "command": "gitDiffExplorer.openFile",
          "when": "view == gitDiffExplorerView && viewItem =~ /^file_/",
          "group": "1_open"
        },
        {
          "command": "gitDiffExplorer.newFile",
          "when": "view == gitDiffExplorerView && viewItem == folder",
          "group": "1_open"
        },
        {
          "command": "gitDiffExplorer.revealInExplorer",
          "when": "view == gitDiffExplorerView",
          "group": "2_nav"
        },
        {
          "command": "gitDiffExplorer.copyPath",
          "when": "view == gitDiffExplorerView",
          "group": "3_copy"
        }
      ]
    },
    "configuration": {
      "title": "XLens",
      "properties": {
        "gitDiffExplorer.baseBranch": {
          "type": "string",
          "default": "",
          "description": "Base branch to compare against. Leave empty to auto-detect (tries master → main → develop → trunk)."
        },
        "gitDiffExplorer.filterPrefix": {
          "type": "string",
          "default": "",
          "description": "Manual filter prefix. Leave empty to auto-detect from workspace folder path relative to git root."
        },
        "gitDiffExplorer.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh when files change or git state updates"
        },
        "gitDiffExplorer.refreshDebounce": {
          "type": "number",
          "default": 2000,
          "description": "Debounce interval in milliseconds for auto-refresh"
        },
        "gitDiffExplorer.autoReveal": {
          "type": "boolean",
          "default": true,
          "description": "Auto-reveal and expand the current editor file in the tree"
        },
        "gitDiffExplorer.statusDisplay": {
          "type": "string",
          "default": "badge",
          "enum": ["badge", "description", "hidden"],
          "enumDescriptions": [
            "Show git status as a colored badge decoration after the file name",
            "Show git status as description text next to the file name",
            "Hide git status indicators entirely"
          ],
          "description": "How to display git status for changed files"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@vscode/vsce": "^3.7.1",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "esbuild": "^0.27.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
}
